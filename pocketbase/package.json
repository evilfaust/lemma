{
  "name": "ege-tasks-pocketbase",
  "version": "1.0.0",
  "description": "PocketBase backend for EGE Tasks with PDF generation",
  "type": "module",
  "scripts": {
    "start": "./pocketbase serve --hooksDir=pb_hooks",
    "pdf": "node pdf-service.js",
    "dev": "concurrently \"npm run start\" \"npm run pdf\""
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "puppeteer": "^24.36.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
