# Конфигурация для Raspberry Pi деплоя
# Скопируйте этот файл в .env и настройте под свою конфигурацию

# IP-адрес Raspberry Pi в локальной сети
RASPBERRY_IP=192.168.1.68

# Пользователь на Raspberry Pi
RASPBERRY_USER=faust

# Директория приложения на Raspberry Pi
RASPBERRY_APP_DIR=/home/faust/ege-app

# Порт PocketBase на Raspberry Pi (внутренний, через nginx)
POCKETBASE_PORT=8090

# Порт PDF-сервиса на Raspberry Pi (внутренний, через nginx)
PDF_SERVICE_PORT=3001

# Внешний порт nginx (публичный доступ)
NGINX_PORT=80
